#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$ROOT/.learninput.pid"

stopped=0

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE")"
  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    for _ in {1..15}; do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.2
    done
    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi
    echo "learninput 已停止 (PID $pid)"
    stopped=1
  fi
  rm -f "$PID_FILE"
fi

# 兜底：清理同目录下残留的 main.py 进程
while IFS= read -r pid; do
  kill "$pid" 2>/dev/null || true
  stopped=1
done < <(pgrep -f "$ROOT/main.py" 2>/dev/null || true)

if [[ "$stopped" -eq 0 ]]; then
  echo "learninput 未在运行"
fi
