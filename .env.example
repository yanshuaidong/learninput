DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 组字停顿多久后触发翻译（毫秒）；越大 API 调用越少，释义出现越晚
DEBOUNCE_MS=700
# 拼音至少多长才请求翻译；短串（如 ni）不会单独打 API
MIN_PINYIN_LENGTH=4
# 选中文案后按此快捷键：中文→英文，英文→中文，均附谐音+音标；macOS 上 alt = Option
TRANSLATE_HOTKEY=alt+e
# 拼音组字面板显示英文后，按此键采纳并粘贴英文（alt+enter = Option+回车）
ACCEPT_HOTKEY=alt+enter
