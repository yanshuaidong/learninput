#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

PID_FILE="$ROOT/.learninput.pid"
LOG_FILE="$ROOT/.learninput.log"

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE")"
  if kill -0 "$pid" 2>/dev/null; then
    echo "learninput 已在运行 (PID $pid)"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

if [[ ! -d "$ROOT/.venv" ]]; then
  echo "创建虚拟环境..."
  python3 -m venv "$ROOT/.venv"
fi

# shellcheck disable=SC1091
source "$ROOT/.venv/bin/activate"

if ! python -c "import webview" 2>/dev/null; then
  echo "安装依赖..."
  pip install -r "$ROOT/requirements.txt" -q
fi

if [[ ! -f "$ROOT/.env" ]]; then
  echo "错误: 未找到 .env"
  echo "请创建 .env 并配置 DEEPSEEK_API_KEY"
  exit 1
fi

nohup python "$ROOT/main.py" >"$LOG_FILE" 2>&1 &
echo $! >"$PID_FILE"

sleep 0.5
if ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  echo "learninput 启动失败，最近日志："
  tail -20 "$LOG_FILE" 2>/dev/null || true
  rm -f "$PID_FILE"
  exit 1
fi

echo "learninput 已启动 (PID $(cat "$PID_FILE"))"
echo "日志: $LOG_FILE"
